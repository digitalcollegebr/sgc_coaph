# =============================================================================
# SGC COAPH — Gestão 360 de Contratos
# Arquivo de exemplo de variáveis de ambiente.
#
# COMO USAR:
#   cp .env.example .env
#   Edite o .env e troque TODOS os valores "change-me" por senhas fortes reais.
#
# IMPORTANTE:
#   - Este arquivo (.env.example) PODE ser versionado no Git.
#   - O arquivo .env REAL NUNCA deve ser versionado (já deve estar no .gitignore).
#   - Nunca commite senhas reais. Aqui só existem placeholders "change-me".
# =============================================================================

# -----------------------------------------------------------------------------
# Identificação do projeto Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=coaph_sgc

# -----------------------------------------------------------------------------
# Site Frappe/ERPNext
# -----------------------------------------------------------------------------
# Nome do site (vira a pasta em sites/ e o host esperado pelo Frappe).
SITE_NAME=sgc.localhost
# Header de host enviado pelo nginx ao backend. Em geral igual ao SITE_NAME.
FRAPPE_SITE_NAME_HEADER=sgc.localhost

# -----------------------------------------------------------------------------
# Senhas (TROCAR TODAS — nunca usar "change-me" em produção)
# -----------------------------------------------------------------------------
# Senha do usuário Administrator do site.
ADMIN_PASSWORD=change-me
# Senha do usuário root do MariaDB.
DB_ROOT_PASSWORD=change-me
# Senha do banco de dados do site (usada pelo Frappe para o banco do site).
DB_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Conexões internas (rede interna do Compose) — normalmente não mexer
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=3306
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
SOCKETIO_PORT=9000

# -----------------------------------------------------------------------------
# Branches (configuráveis — usadas no BUILD da imagem customizada)
# -----------------------------------------------------------------------------
FRAPPE_BRANCH=version-16
ERPNEXT_BRANCH=version-16
COAPH_APP_BRANCH=main

# -----------------------------------------------------------------------------
# Portas expostas no servidor
# (8080 está OCUPADA no servidor, por isso usamos 8081 para HTTP)
# -----------------------------------------------------------------------------
HTTP_PORT=8081
HTTPS_PORT=8443

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TIMEZONE=America/Fortaleza

# -----------------------------------------------------------------------------
# Imagem customizada publicada no Docker Hub
# Em produção o servidor faz `docker compose pull` desta imagem.
# -----------------------------------------------------------------------------
CUSTOM_IMAGE=danielmonteirodc/sgc-erpnext
CUSTOM_TAG=version-16
